{
  "name": "@nteract/sift",
  "version": "0.3.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./handoff": "./src/handoff.tsx",
    "./style.css": "./src/style.css",
    "./handoff.css": "./src/handoff.css"
  },
  "publishConfig": {
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "exports": {
      ".": {
        "import": "./lib/index.js",
        "types": "./lib/index.d.ts"
      },
      "./handoff": {
        "import": "./lib/handoff.js",
        "types": "./lib/handoff.d.ts"
      },
      "./style.css": "./lib/style.css",
      "./handoff.css": "./lib/handoff.css"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "generate": "npx tsx src/generate-data.ts",
    "dev": "vp dev",
    "build": "tsc && vp build",
    "build:lib": "tsc && vp build --config vite.lib.config.ts && node scripts/build-lib-css.mjs && cp src/handoff.css lib/handoff.css",
    "preview": "vp preview",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:e2e": "playwright test",
    "cache-datasets": "npx tsx scripts/cache-datasets.ts"
  },
  "peerDependencies": {
    "@chenglou/pretext": ">=0.0.6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "apache-arrow": "^21.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vite-plus": "catalog:"
  },
  "dependencies": {
    "@chenglou/pretext": ">=0.0.6",
    "@nteract/odometer": "workspace:*",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.513.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1"
  }
}
