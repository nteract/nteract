# Generated isolated-renderer bundle (built from src/isolated-renderer)
apps/notebook/public/isolated/

# Built MCP Apps widget (generated by apps/mcp-app build)
python/nteract/src/nteract/_widget.html

# Volatile renderer-plugin bundles. sift.js / sift.css re-embed sift-wasm's
# wasm-bindgen glue and must be rebuilt whenever the WASM side changes, so
# they stay out of git. Stable bundles (plotly, vega, leaflet, markdown,
# isolated-renderer) are LFS-tracked — see `.gitattributes`.
/apps/notebook/src/renderer-plugins/sift.js
/apps/notebook/src/renderer-plugins/sift.css
# wasm-pack outputs, rebuilt on every `cargo xtask build` via xtask's
# volatile-wasm force-rebuild path.
/apps/notebook/src/wasm/runtimed-wasm/
/crates/sift-wasm/pkg/

