# Stable third-party renderer-plugin bundles. LFS-tracked so fresh checkouts
# don't pay the large vendor rebuild just to boot the daemon. Owned/generated
# bundles (isolated-renderer.*, markdown.*, sift.*) stay gitignored and are
# rebuilt by xtask/bootstrap so ordinary builds do not churn LFS pointers.
apps/notebook/src/renderer-plugins/plotly.js filter=lfs diff=lfs merge=lfs -text
apps/notebook/src/renderer-plugins/vega.js filter=lfs diff=lfs merge=lfs -text
apps/notebook/src/renderer-plugins/leaflet.js filter=lfs diff=lfs merge=lfs -text
apps/notebook/src/renderer-plugins/leaflet.css filter=lfs diff=lfs merge=lfs -text

# Notebook/runtime-state fixture snapshots. Small today (~60KB total), but
# they're opaque Automerge binaries — regular git storage would bloat history
# each time we regenerate them for a schema change.
packages/runtimed/tests/fixtures/**/*.bin filter=lfs diff=lfs merge=lfs -text

# Docs catalog static copy of the Sift WASM runtime. This lets apps/elements
# exercise @nteract/sift URL loading without depending on ignored local
# wasm-pack outputs at build time.
apps/elements/public/wasm/sift_wasm_bg.wasm filter=lfs diff=lfs merge=lfs -text
