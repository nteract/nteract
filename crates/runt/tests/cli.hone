#! shell: /bin/bash
#! timeout: 60s

TEST "no command shows help message"
RUN runt
ASSERT exit_code == 0
ASSERT stdout contains "No command specified. Use --help for usage information."

TEST "help flag displays usage"
RUN runt --help
ASSERT exit_code == 0
ASSERT stdout contains "Usage: runt [COMMAND]"

TEST "version flag displays version"
RUN runt --version
ASSERT exit_code == 0
ASSERT stdout matches /runt \d+\.\d+\.\d+/

TEST "nb namespace exposes notebook tool bridge"
RUN runt nb --help
ASSERT exit_code == 0
ASSERT stdout contains "Headless notebook operations backed by the MCP tool surface"

TEST "nb tools lists MCP-compatible notebook operations"
RUN runt nb tools
ASSERT exit_code == 0
ASSERT stdout contains "create_cell"
ASSERT stdout contains "execute_cell"
ASSERT stdout contains "manage_dependencies"
ASSERT stdout contains "Additional callable read tools: get_cell, get_all_cells"

TEST "nb tools all includes dispatch-only read operations"
RUN runt nb tools --all
ASSERT exit_code == 0
ASSERT stdout contains "get_cell"
ASSERT stdout contains "get_all_cells"

TEST "invalid command fails"
RUN runt invalid_command
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'invalid_command'"

TEST "removed jupyter namespace fails"
RUN runt jupyter
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'jupyter'"

TEST "removed standalone start command fails"
RUN runt start python3
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'start'"

TEST "removed standalone stop-kernel command fails"
RUN runt stop-kernel 00000000-0000-0000-0000-000000000000
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'stop-kernel'"

TEST "removed standalone interrupt command fails"
RUN runt interrupt 00000000-0000-0000-0000-000000000000
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'interrupt'"

TEST "removed standalone exec command fails"
RUN runt exec 00000000-0000-0000-0000-000000000000 "print('hello')"
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'exec'"

TEST "removed standalone console command fails"
RUN runt console
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'console'"

TEST "removed standalone clean command fails"
RUN runt clean
ASSERT exit_code != 0
ASSERT stderr contains "error: unrecognized subcommand 'clean'"
