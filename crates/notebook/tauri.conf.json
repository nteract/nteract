{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nteract",
  "version": "2.4.7",
  "identifier": "org.nteract.desktop",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "../../apps/notebook/dist",
    "beforeDevCommand": "pnpm --dir apps/notebook dev",
    "beforeBuildCommand": "pnpm --dir apps/notebook build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: http://127.0.0.1:* https:",
        "font-src": "'self' data:",
        "media-src": "'self' data: blob: http://127.0.0.1:* https:",
        "object-src": "'self' data: blob: http://127.0.0.1:*",
        "frame-src": "blob:",
        "child-src": "blob:",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:*",
        "base-uri": "'none'",
        "form-action": "'none'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:5174",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' http://localhost:5174",
        "style-src": "'self' 'unsafe-inline' http://localhost:5174",
        "img-src": "'self' data: blob: http://127.0.0.1:* http://localhost:* https:",
        "font-src": "'self' data: http://localhost:*",
        "media-src": "'self' data: blob: http://127.0.0.1:* http://localhost:* https:",
        "object-src": "'self' data: blob: http://127.0.0.1:* http://localhost:*",
        "frame-src": "blob: http://localhost:*",
        "child-src": "blob: http://localhost:*",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*",
        "base-uri": "'none'",
        "form-action": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/runtimed", "binaries/runt", "binaries/nteract-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["ipynb"],
        "mimeType": "application/x-ipynb+json",
        "name": "Jupyter Notebook",
        "role": "Editor"
      }
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net -a NumFOCUS -c TrustedCertificateProfileForALLNumFOCUS -d nteract %1",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "installerHooks": "nsis/bootstrap.nsh"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "desktopTemplate": null
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREODExMjdBRTEwMTgxODEKUldTQmdRSGhlaEtCM2Mwek9ZcXZUVE5ISFdvbnVWa2wrbWFNb3dZNVVILzhTWGZwYUhHLzhEeEcK",
      "endpoints": [
        "https://github.com/nteract/desktop/releases/download/stable-latest/latest.json"
      ]
    }
  }
}
