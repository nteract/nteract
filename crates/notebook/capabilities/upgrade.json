{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "upgrade",
  "description": "Minimal capabilities for the upgrade window",
  "windows": ["upgrade"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-close",
    "process:allow-restart",
